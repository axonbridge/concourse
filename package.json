{
  "name": "concourse",
  "version": "0.7.3",
  "description": "Desktop control surface for managing agentic coding work across many projects.",
  "license": "MIT",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "check:node": "node scripts/require-node-24.mjs",
    "setup:whisper": "node scripts/fetch-whisper.mjs",
    "preinstall": "node scripts/require-node-24.mjs",
    "predev": "node scripts/require-node-24.mjs",
    "predev:electron": "node scripts/require-node-24.mjs",
    "predev:server": "node scripts/require-node-24.mjs",
    "prebuild": "node scripts/require-node-24.mjs",
    "prebuild:web": "node scripts/require-node-24.mjs",
    "prebuild:electron": "node scripts/require-node-24.mjs",
    "predist:mac": "node scripts/require-node-24.mjs",
    "predist:win": "node scripts/require-node-24.mjs",
    "predist:linux": "node scripts/require-node-24.mjs",
    "predist:all": "node scripts/require-node-24.mjs",
    "pregenerate:routes": "node scripts/require-node-24.mjs",
    "pretypecheck": "node scripts/require-node-24.mjs",
    "prelint": "node scripts/require-node-24.mjs",
    "pretest": "node scripts/require-node-24.mjs",
    "prescan:secrets": "node scripts/require-node-24.mjs",
    "predb:generate": "node scripts/require-node-24.mjs",
    "predb:push": "node scripts/require-node-24.mjs",
    "prenative:node": "node scripts/require-node-24.mjs",
    "prenative:node:rebuild": "node scripts/require-node-24.mjs",
    "prenative:electron:sqlite": "node scripts/require-node-24.mjs",
    "prenative:electron:sqlite:source": "node scripts/require-node-24.mjs",
    "prenative:electron:pty": "node scripts/require-node-24.mjs",
    "prenative:electron": "node scripts/require-node-24.mjs",
    "prerebuild": "node scripts/require-node-24.mjs",
    "prepackage": "node scripts/require-node-24.mjs",
    "predist": "node scripts/require-node-24.mjs",
    "prerelease:local": "node scripts/require-node-24.mjs",
    "pregen:theme-images": "node scripts/require-node-24.mjs",
    "dev": "corepack pnpm@11.1.2 dev:electron",
    "dev:electron": "node scripts/dev-local.mjs electron",
    "dev:server": "corepack pnpm@11.1.2 native:node && vite --strictPort",
    "dev:electron:main": "node scripts/ensure-electron-sqlite.mjs && tsc -p electron/tsconfig.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}))\" && cross-env NODE_ENV=development electron dist-electron/electron/main.js",
    "build:web": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}))\" && node -e \"require('fs').copyFileSync('electron/server-runner.mjs','dist-electron/electron/server-runner.mjs')\"",
    "build": "pnpm build:web && pnpm build:electron",
    "package": "pnpm build && pnpm native:electron && electron-builder",
    "dist": "pnpm build && pnpm native:electron && electron-builder --publish never",
    "dist:mac": "pnpm build && pnpm native:electron && electron-builder --mac --publish never",
    "dist:win": "pnpm build && pnpm native:electron && electron-builder --win --publish never",
    "dist:linux": "pnpm build && pnpm native:electron && electron-builder --linux --publish never",
    "dist:all": "pnpm build && pnpm native:electron && electron-builder -mwl --publish never",
    "generate:routes": "node scripts/generate-routes.mjs",
    "typecheck": "pnpm generate:routes && tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "lint": "eslint src electron scripts *.config.ts",
    "test": "pnpm native:node && vitest run",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "db:generate": "pnpm native:node && drizzle-kit generate",
    "db:push": "pnpm native:node && drizzle-kit push",
    "native:node": "node scripts/ensure-node-sqlite.mjs",
    "native:node:rebuild": "pnpm rb better-sqlite3",
    "native:electron:sqlite": "node scripts/ensure-electron-sqlite.mjs",
    "native:electron:sqlite:source": "cross-env npm_config_build_from_source=true electron-rebuild -f -o better-sqlite3",
    "native:electron:pty": "electron-rebuild -f -o node-pty",
    "native:electron": "pnpm native:electron:sqlite && pnpm native:electron:pty",
    "rebuild": "pnpm native:electron",
    "release:local": "node scripts/release-local.mjs",
    "gen:theme-images": "node scripts/gen-theme-images.mjs",
    "postinstall": "pnpm native:electron || true"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.195",
    "@catppuccin/codemirror": "1.0.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/theme-one-dark": "6.1.3",
    "@fontsource/geist-mono": "5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/space-grotesk": "5.2.10",
    "@lezer/common": "1.5.2",
    "@lezer/highlight": "1.2.3",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tanstack/react-query": "5.100.10",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-router-with-query": "1.130.17",
    "@tanstack/react-start": "1.167.65",
    "@uiw/react-codemirror": "4.25.9",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "better-sqlite3": "12.10.0",
    "double-metaphone": "2.0.1",
    "drizzle-orm": "0.45.2",
    "electron-log": "5.4.4",
    "electron-updater": "6.8.3",
    "ignore": "7.0.5",
    "lucide-react": "1.16.0",
    "mermaid": "11.12.0",
    "node-pty": "1.1.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-icons": "5.6.0",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "sonner": "2.0.7",
    "tar": "7.5.15",
    "ws": "8.21.0",
    "zod": "4.4.3",
    "adm-zip": "0.5.18"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.4",
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/router-plugin": "1.167.35",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.8.0",
    "@types/pngjs": "6.0.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "drizzle-kit": "0.31.10",
    "electron": "41.6.1",
    "electron-builder": "26.8.2",
    "esbuild": "0.28.1",
    "eslint": "10.4.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "pngjs": "7.0.0",
    "puppeteer": "24.43.1",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13",
    "vitest": "4.1.6",
    "wait-on": "9.0.10",
    "@types/adm-zip": "0.5.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "node-pty",
      "protobufjs"
    ]
  },
  "build": {
    "appId": "labs.agentsystem.concourse",
    "productName": "Concourse",
    "files": [
      "dist/**/*",
      "!dist/**/*.dmg",
      "!dist/**/*.AppImage",
      "!dist/**/*.exe",
      "!dist/builder-*.yml",
      "!dist/builder-*.yaml",
      "!dist/mac*/**/*",
      "!dist/win*/**/*",
      "!dist/linux*/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist-electron-out",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "resources/whisper",
        "to": "whisper",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Concourse uses the microphone for push-to-talk voice commands. Audio is transcribed locally on your machine and never leaves your computer."
      },
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://agentsystem.dev/downloads/concourse/auto-update",
        "channel": "latest"
      }
    ]
  },
  "volta": {
    "node": "24.18.0"
  }
}
